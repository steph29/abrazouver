# Exemple de configuration Nginx pour l'API en HTTPS
# À placer dans /etc/nginx/sites-available/ puis activer
# Remplacer api.votredomaine.com par votre sous-domaine API

server {
    listen 80;
    server_name api.votredomaine.com;
    return 301 https://$server_name$request_uri;
}

server {
    listen 443 ssl;
    server_name api.votredomaine.com;

    # Certificats Let's Encrypt (générés par certbot)
    ssl_certificate /etc/letsencrypt/live/api.votredomaine.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/api.votredomaine.com/privkey.pem;

    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
